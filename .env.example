RESTAURANT_ADMIN_USERNAME=admin
RESTAURANT_ADMIN_PASSWORD=change-this-password
RESTAURANT_SESSION_TTL_SECONDS=86400
RESTAURANT_PASSWORD_ITERATIONS=210000
RESTAURANT_ALLOWED_ORIGINS=https://your-project.vercel.app
RESTAURANT_MAX_JSON_BODY_BYTES=131072

# Brute-force / abuse protection (in-process best-effort).
# Lock a (client IP, role, username) after this many failed logins in the window.
RESTAURANT_LOGIN_MAX_FAILURES=5
RESTAURANT_LOGIN_FAILURE_WINDOW_SECONDS=900
# Burst limit per client for register, per user for order creation.
RESTAURANT_RATE_LIMIT_MAX=60
RESTAURANT_RATE_LIMIT_WINDOW_SECONDS=60
RESTAURANT_APP_VERSION=production
RESTAURANT_DB_SCHEMA=restaurant_app
RESTAURANT_DB_SSLMODE=require

# Supabase Transaction Pooler connection string for Vercel/serverless.
# Example:
# DATABASE_URL=postgres://postgres.project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Safer alternative to DATABASE_URL. If these are set, they take precedence and
# the password does not need URL encoding.
RESTAURANT_DB_HOST=aws-0-region.pooler.supabase.com
RESTAURANT_DB_PORT=6543
RESTAURANT_DB_NAME=postgres
RESTAURANT_DB_USER=postgres.project-ref
RESTAURANT_DB_PASSWORD=

# Local SQLite only. Do not set this on Vercel unless it points to a mounted persistent database path.
RESTAURANT_DB_PATH=server/restaurant.db
